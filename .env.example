# Frontend
# Deixe vazio em dev (o Vite faz proxy de /api → :3001). Em produção, aponte para a URL do backend.
VITE_API_URL=

# Backend
PORT=3001

# OpenRouter API (for AI analysis)
# Get your API key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE
# Opcional: sobrescreve o modelo padrão (openai/gpt-oss-120b:free - melhor modelo gratuito da OpenRouter)
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
