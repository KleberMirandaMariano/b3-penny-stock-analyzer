# ============================================================
# FRONTEND (Vite — variáveis devem começar com VITE_)
# ============================================================

# URL base do backend Express.
# Em desenvolvimento: http://localhost:3001 (ou vazio para usar o proxy do Vite)
# Em produção (Vercel): URL pública do serviço no Render
VITE_API_URL=http://localhost:3001

# ============================================================
# BACKEND (Express / Node)
# ============================================================

# Porta do servidor Express (default: 3001)
PORT=3001

# ============================================================
# OLLAMA / LLM LOCAL (para análise de opções)
# ============================================================

# URL do servidor Ollama (default: http://localhost:11434)
# Para usar VPS Hostinger: https://seu-vps.com:11434
OLLAMA_URL=http://localhost:11434

# Modelo Llama a usar (default: llama2)
# Outras opções: llama3, neural-chat, mistral, etc
OLLAMA_MODEL=llama2

# ============================================================
# PYTHON SCRIPTS (opcional)
# ============================================================

# Chave Gemini (caso os scripts de coleta usem IA)
# GEMINI_API_KEY=sua_chave_aqui
